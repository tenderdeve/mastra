{
  "name": "@mastra/claude-agent-sdk",
  "version": "0.0.1-alpha.0",
  "description": "Claude Agent SDK integration for Mastra — first-class ClaudeAgent shell, session persistence, approvals, questions, and OTLP trace ingest",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build:lib": "tsup --silent --config tsup.config.ts",
    "build:watch": "pnpm build:lib --watch",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "keywords": [
    "mastra",
    "claude",
    "claude-code",
    "claude-agent-sdk",
    "anthropic",
    "integration"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mastra-ai/mastra.git",
    "directory": "integrations/claude-agent-sdk"
  },
  "bugs": {
    "url": "https://github.com/mastra-ai/mastra/issues"
  },
  "homepage": "https://mastra.ai",
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.112",
    "@mastra/core": "workspace:*",
    "@mastra/schema-compat": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@internal/lint": "workspace:*",
    "@internal/types-builder": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
